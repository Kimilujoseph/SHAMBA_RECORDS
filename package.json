{
  "name": "smartseason-backend",
  "version": "1.0.0",
  "description": "Backend for SmartSeason Field Monitoring System",
  "main": "dist/server.js",
  "scripts": {
    "build": "rimraf dist && tsc",
    "prestart": "npm run build",
    "start": "NODE_ENV=production node dist/server.js",
    "dev": "cross-env NODE_ENV=development ts-node-dev --respawn --transpile-only src/server.ts",
    "test": "jest",
    "prisma:migrate-dev": "npx prisma migrate dev --name init",
    "prisma:generate": "npx prisma generate --schema=src/infrastructure/database/prisma/schema.prisma"
  },
  "keywords": [
    "smartseason",
    "backend",
    "nodejs",
    "typescript",
    "express",
    "prisma"
  ],
  "author": "SmartSeason Team",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^6.4.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.8",
    "@types/morgan": "^1.9.9",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "nodemon": "^3.1.7",
    "prisma": "^6.4.0",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3"
  }
}
