{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext", // Use "esnext" if you're using ES module imports
    "moduleResolution": "nodenext", // Important for resolving node modules
    "esModuleInterop": true, // Enables default import interoperability with CommonJS
    "outDir": "./dist",
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules"]
}
